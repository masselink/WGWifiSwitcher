<Window x:Class="WGWifiSwitcher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:WGWifiSwitcher"
        Title="WireGuard WiFi Switcher"
        Height="640" Width="960"
        MinHeight="500" MinWidth="780"
        Background="{StaticResource Bg}"
        WindowStyle="None"
        AllowsTransparency="True"
        ShowInTaskbar="True"
        ResizeMode="CanResizeWithGrip"
        Closing="Window_Closing">

    <Window.Resources>
        <!-- Section label style -->
        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="Foreground"  Value="{StaticResource Sub}"/>
            <Setter Property="FontFamily"  Value="Consolas"/>
            <Setter Property="FontSize"    Value="10"/>
            <Setter Property="FontWeight"  Value="Bold"/>
            <Setter Property="Margin"      Value="0,0,0,6"/>
        </Style>
    </Window.Resources>

    <Border BorderBrush="{StaticResource Border}" BorderThickness="1" CornerRadius="6">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="48"/>  <!-- Title bar -->
                <RowDefinition Height="38"/>  <!-- Status bar -->
                <RowDefinition Height="1"/>   <!-- Divider -->
                <RowDefinition Height="*"/>   <!-- Content -->
                <RowDefinition Height="28"/>  <!-- Footer -->
            </Grid.RowDefinitions>

            <!-- ── Custom title bar ─────────────────────────────────────── -->
            <Border Grid.Row="0" Background="{StaticResource Panel}"
                    CornerRadius="6,6,0,0"
                    MouseLeftButtonDown="TitleBar_MouseDown">
                <Grid>
                    <!-- Shield icon + title -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0">
                        <Path Data="M12,1 L22,5 L22,13 C22,18 17,22 12,24 C7,22 2,18 2,13 L2,5 Z"
                              Fill="{StaticResource Accent}" Width="18" Height="20"
                              Stretch="Uniform" Margin="0,0,10,0"/>
                        <TextBlock Text="WireGuard WiFi Switcher"
                                   FontSize="14" FontWeight="Bold"
                                   Foreground="{StaticResource Accent}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Window controls -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                                VerticalAlignment="Center" Margin="0,0,8,0">
                        <Button Content="—" Style="{StaticResource FlatBtn}"
                                Padding="10,4" BorderThickness="0" Background="Transparent"
                                Click="MinimizeBtn_Click" ToolTip="Minimise to tray"/>
                        <Button Content="✕" Style="{StaticResource DangerBtn}"
                                Padding="10,4" BorderThickness="0" Background="Transparent"
                                Click="CloseBtn_Click" ToolTip="Minimise to tray"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ── Status bar ───────────────────────────────────────────── -->
            <Border Grid.Row="1" Background="{StaticResource Panel}">
                <Grid Margin="16,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="WiFi:" Foreground="{StaticResource Sub}"
                               FontSize="11" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" x:Name="WifiLabel" Text="Scanning…"
                               FontSize="11" FontWeight="Bold" Margin="6,0,0,0"
                               VerticalAlignment="Center"/>

                    <Rectangle Grid.Column="2" Width="1" Height="14" Margin="16,0"
                                Fill="{StaticResource Border}" VerticalAlignment="Center"/>

                    <TextBlock Grid.Column="3" Text="Active tunnel:" Foreground="{StaticResource Sub}"
                               FontSize="11" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="4" x:Name="TunnelLabel" Text="—"
                               FontSize="11" FontWeight="Bold" Margin="6,0,0,0"
                               Foreground="{StaticResource Green}" VerticalAlignment="Center"/>

                    <Button Grid.Column="6" Content="↻  Check Active Tunnels"
                            Style="{StaticResource FlatBtn}" FontSize="10"
                            Click="RefreshTunnels_Click" VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <Rectangle Grid.Row="2" Fill="{StaticResource Border}"/>

            <!-- ── Main content ──────────────────────────────────────────── -->
            <Grid Grid.Row="3" Margin="14,12,14,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="3*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="2*"/>
                </Grid.ColumnDefinitions>

                <!-- LEFT: Rules list -->
                <Grid Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="NETWORK → TUNNEL RULES"
                               Style="{StaticResource SectionLabel}"/>

                    <ListView Grid.Row="1" x:Name="RulesListView"
                              SelectionChanged="RulesListView_SelectionChanged">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="WiFi Network (SSID)" Width="220"
                                    DisplayMemberBinding="{Binding Ssid}"/>
                                <GridViewColumn Header="WireGuard Tunnel" Width="180"
                                    DisplayMemberBinding="{Binding TunnelDisplay}"/>
                                <GridViewColumn Header="Status" Width="90">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding StatusText}"
                                                       Foreground="{Binding StatusColor}"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                            </GridView>
                        </ListView.View>
                    </ListView>

                    <!-- Rule buttons -->
                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,8,0,0">
                        <Button Content="＋  Add Rule"  Style="{StaticResource GreenBtn}"
                                Click="AddRule_Click"/>
                        <Button Content="✎  Edit"      Style="{StaticResource FlatBtn}"
                                Margin="8,0" Click="EditRule_Click"
                                x:Name="EditBtn" IsEnabled="False"/>
                        <Button Content="✕  Delete"    Style="{StaticResource DangerBtn}"
                                Click="DeleteRule_Click"
                                x:Name="DeleteBtn" IsEnabled="False"/>
                        <Button Content="▶  Activate"  Style="{StaticResource GreenBtn}"
                                Margin="6,0,0,0"
                                Click="ActivateRule_Click"
                                x:Name="ActivateBtn" IsEnabled="False"/>
                    </StackPanel>
                </Grid>

                <!-- RIGHT: Default action + log -->
                <Grid Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="16"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Default action panel -->
                    <TextBlock Grid.Row="0" Text="DEFAULT ACTION"
                               Style="{StaticResource SectionLabel}"/>

                    <Border Grid.Row="1" Background="{StaticResource Card}"
                            BorderBrush="{StaticResource Border}" BorderThickness="1"
                            CornerRadius="4" Padding="12,10">
                        <StackPanel>
                            <TextBlock Text="When no rule matches:" FontSize="10"
                                       Foreground="{StaticResource Sub}" Margin="0,0,0,8"/>
                            <RadioButton x:Name="ActionNone"   Content="Do nothing"
                                         Checked="DefaultAction_Changed" Tag="none"/>
                            <RadioButton x:Name="ActionDiscon" Content="Disconnect all tunnels"
                                         Checked="DefaultAction_Changed" Tag="disconnect"/>
                            <RadioButton x:Name="ActionActivate" Margin="0,3,0,0"
                                         Checked="DefaultAction_Changed" Tag="activate">
                                <RadioButton.Content>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Activate tunnel:" VerticalAlignment="Center"/>
                                        <TextBox x:Name="DefaultTunnelBox" Margin="8,0,0,0"
                                                 MinWidth="120" FontSize="11"
                                                 TextChanged="DefaultTunnelBox_TextChanged"
                                                 LostFocus="DefaultTunnelBox_LostFocus"/>
                                    </StackPanel>
                                </RadioButton.Content>
                            </RadioButton>
                        </StackPanel>
                    </Border>

                    <!-- Activity log -->
                    <TextBlock Grid.Row="3" Text="ACTIVITY LOG"
                               Style="{StaticResource SectionLabel}"/>

                    <Border Grid.Row="4" Background="{StaticResource Card}"
                            BorderBrush="{StaticResource Border}" BorderThickness="1"
                            CornerRadius="4">
                        <RichTextBox x:Name="LogBox"
                                     Background="{StaticResource Card}"
                                     Foreground="{StaticResource Sub}"
                                     FontFamily="Consolas" FontSize="10"
                                     BorderThickness="0" IsReadOnly="True"
                                     Padding="8"
                                     VerticalScrollBarVisibility="Auto"
                                     HorizontalScrollBarVisibility="Disabled">
                            <FlowDocument x:Name="LogDocument" PageWidth="9999">
                            </FlowDocument>
                        </RichTextBox>
                    </Border>
                </Grid>
            </Grid>

            <!-- ── Footer ────────────────────────────────────────────────── -->
            <Border Grid.Row="4" Background="{StaticResource Panel}"
                    CornerRadius="0,0,6,6">
                <Grid Margin="14,0">
                    <TextBlock x:Name="FooterLabel" Text="Ready"
                               Foreground="{StaticResource Sub}" FontSize="10"
                               VerticalAlignment="Center"/>
                    <TextBlock x:Name="AdminLabel"
                               HorizontalAlignment="Right" FontSize="10"
                               VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- Resize grip -->
            <ResizeGrip Grid.Row="4" HorizontalAlignment="Right"
                        VerticalAlignment="Bottom" Margin="0,0,2,2"
                        Opacity="0.4"/>
        </Grid>
    </Border>
</Window>
