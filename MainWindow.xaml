<Window x:Class="MasselGUARD.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:MasselGUARD"
        Title="{Binding [AppTitle], Source={x:Static local:Lang.Instance}}"
        Height="640" Width="1200"
        MinHeight="500" MinWidth="980"
        Background="{DynamicResource WindowBg}"
        WindowStyle="None"
        AllowsTransparency="True"
        ShowInTaskbar="True"
        ResizeMode="CanResizeWithGrip"
        Opacity="{DynamicResource Theme.WindowOpacity}"
        Closing="Window_Closing">

    <Window.Resources>
    </Window.Resources>

    <Border BorderBrush="{DynamicResource BorderColor}" BorderThickness="1"
            CornerRadius="{DynamicResource Theme.CornerRadius}">
        <Grid>
            <!-- Optional background image layer -->
            <Border CornerRadius="{DynamicResource Theme.CornerRadius}"
                    Visibility="{DynamicResource Theme.HasBackground}">
                <Border.Background>
                    <DynamicResourceExtension ResourceKey="Theme.BackgroundBrush"/>
                </Border.Background>
            </Border>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="{DynamicResource Theme.TitleBarHeight}"/>
                    <RowDefinition Height="{DynamicResource Theme.StatusBarHeight}"/>
                    <RowDefinition Height="1"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="28"/>
                </Grid.RowDefinitions>

                <!-- ── Title bar ──────────────────────────────────────────── -->
                <Border Grid.Row="0" Background="{DynamicResource Surface}"
                        CornerRadius="{DynamicResource Theme.CornerRadiusTop}"
                        MouseLeftButtonDown="TitleBar_MouseDown">
                    <Grid>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0">

                            <!-- Icon group: ShowTitleBarIcon=false hides all variants -->
                            <StackPanel Orientation="Horizontal"
                                        Visibility="{DynamicResource Theme.ShowTitleBarIcon}">

                                <!-- Custom logo (theme override) -->
                                <Image x:Name="TitleLogo"
                                       Source="{DynamicResource Theme.Logo}"
                                       Width="{DynamicResource Theme.LogoWidth}"
                                       Height="{DynamicResource Theme.LogoHeight}"
                                       Visibility="{DynamicResource Theme.HasLogo}"
                                       Margin="0,0,10,0"
                                       RenderOptions.BitmapScalingMode="HighQuality"/>

                                <!-- Built-in shield icon (shown when no logo set) -->
                                <Viewbox Width="22" Height="24" Margin="0,0,10,0" Stretch="Uniform"
                                         Visibility="{DynamicResource Theme.HasBuiltinIcon}">
                                    <Canvas Width="24" Height="24">
                                        <Path Fill="{DynamicResource CardBg}" Stroke="{DynamicResource BorderColor}" StrokeThickness="1.2">
                                            <Path.Data>M12,1 L22,5 L22,13 C22,18.5 17.5,22.5 12,24 C6.5,22.5 2,18.5 2,13 L2,5 Z</Path.Data>
                                        </Path>
                                        <Polyline Points="7,9 12,15 17,9"
                                                  Stroke="{DynamicResource Accent}" StrokeThickness="2.2"
                                                  StrokeLineJoin="Round"
                                                  StrokeStartLineCap="Round"
                                                  StrokeEndLineCap="Round"
                                                  Fill="Transparent"/>
                                    </Canvas>
                                </Viewbox>
                            </StackPanel>

                            <!-- App name from theme -->
                            <TextBlock Text="{DynamicResource Theme.AppName}"
                                       FontFamily="{DynamicResource Theme.FontFamily}"
                                       FontSize="14" FontWeight="Bold"
                                       Foreground="{DynamicResource Accent}"
                                       VerticalAlignment="Center"
                                       Visibility="{DynamicResource Theme.ShowTitleBarAppName}"/>

                        </StackPanel>

                        <!-- Window controls: theme toggle + settings cog + close -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                                    VerticalAlignment="Center" Margin="0,0,8,0">
                            <Button x:Name="ThemeToggleBtn"
                                    Content="🌙" FontSize="13" Padding="8,4" Margin="0,0,2,0"
                                    Style="{StaticResource FlatBtn}"
                                    Click="ThemeToggle_Click"
                                    ToolTip="Switch theme mode (Dark / Light / Auto)"/>
                            <Button Content="⚙" Style="{StaticResource FlatBtn}"
                                    FontSize="14" Padding="8,4" Margin="0,0,4,0"
                                    Click="SettingsBtn_Click"
                                    ToolTip="{Binding [TooltipSettings], Source={x:Static local:Lang.Instance}}"/>
                            <Button Content="✕" Style="{StaticResource DangerBtn}"
                                    Padding="10,4" BorderThickness="0" Background="Transparent"
                                    Click="CloseBtn_Click"
                                    ToolTip="{Binding [TooltipClose], Source={x:Static local:Lang.Instance}}"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- ── Status bar ─────────────────────────────────────────── -->
                <Border Grid.Row="1" Background="{DynamicResource Surface}"
                        Visibility="{DynamicResource Theme.ShowStatusBar}">
                    <Grid Margin="16,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Text="{Binding [StatusWifi], Source={x:Static local:Lang.Instance}}"
                                   Foreground="{DynamicResource TextMuted}" FontSize="11" VerticalAlignment="Center"
                                   Visibility="{DynamicResource Theme.ShowStatusWifi}"/>
                        <TextBlock Grid.Column="1" x:Name="WifiLabel"
                                   Text="{Binding [StatusScanning], Source={x:Static local:Lang.Instance}}"
                                   FontSize="11" FontWeight="Bold" Margin="6,0,0,0"
                                   VerticalAlignment="Center"
                                   Visibility="{DynamicResource Theme.ShowStatusWifi}"/>

                        <Rectangle Grid.Column="2" Width="1" Height="14" Margin="16,0"
                                   Fill="{DynamicResource BorderColor}" VerticalAlignment="Center"/>

                        <TextBlock Grid.Column="3"
                                   Text="{Binding [StatusActiveTunnel], Source={x:Static local:Lang.Instance}}"
                                   Foreground="{DynamicResource TextMuted}" FontSize="11" VerticalAlignment="Center"
                                   Visibility="{DynamicResource Theme.ShowStatusTunnel}"/>
                        <TextBlock Grid.Column="4" x:Name="TunnelLabel"
                                   Text="{Binding [StatusNone], Source={x:Static local:Lang.Instance}}"
                                   FontSize="11" FontWeight="Bold" Margin="6,0,0,0"
                                   Foreground="{DynamicResource Success}" VerticalAlignment="Center"
                                   Visibility="{DynamicResource Theme.ShowStatusTunnel}"/>

                        <!-- Action buttons — right-aligned in column 6 -->
                        <StackPanel Grid.Column="6" Orientation="Horizontal"
                                    HorizontalAlignment="Right" VerticalAlignment="Center"
                                    Margin="0,0,4,0">
                            <Button x:Name="QuickConnectBtn"
                                    Content="{Binding [BtnQuickConnect], Source={x:Static local:Lang.Instance}}"
                                    Style="{StaticResource FlatBtn}" FontSize="10" Padding="10,3"
                                    Visibility="Collapsed"
                                    ToolTip="{Binding [TooltipQuickConnect], Source={x:Static local:Lang.Instance}}"
                                    Click="QuickConnect_Click"/>
                            <Button x:Name="OpenWgBtn"
                                    Content="{Binding [BtnOpenWireGuard], Source={x:Static local:Lang.Instance}}"
                                    Style="{StaticResource FlatBtn}" FontSize="10" Padding="10,3"
                                    Margin="6,0,0,0" Visibility="Collapsed"
                                    ToolTip="{Binding [TooltipWireGuard], Source={x:Static local:Lang.Instance}}"
                                    Click="OpenWireGuardGui_Click"/>
                            <Button x:Name="WireGuardLogBtn"
                                    Content="{Binding [BtnShowLog], Source={x:Static local:Lang.Instance}}"
                                    Style="{StaticResource FlatBtn}" FontSize="10" Padding="10,3"
                                    Margin="6,0,0,0" Visibility="Collapsed"
                                    ToolTip="{Binding [TooltipLog], Source={x:Static local:Lang.Instance}}"
                                    Click="ShowWireGuardLog_Click"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <Rectangle Grid.Row="2" Fill="{DynamicResource BorderColor}"/>

                <!-- ── Error banner (hidden by default) ── -->
                <Border Grid.Row="3" x:Name="ErrorBanner"
                        Background="{DynamicResource ErrorBg}" BorderBrush="{DynamicResource ErrorColor}" BorderThickness="0,0,0,1"
                        Padding="14,6" Visibility="Collapsed">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="ErrorBannerText" Grid.Column="0"
                                   FontSize="11" Foreground="{DynamicResource ErrorColor}"
                                   TextWrapping="Wrap" VerticalAlignment="Center"/>
                        <Button Grid.Column="1" Content="✕"
                                Style="{StaticResource DangerBtn}"
                                FontSize="11" Padding="8,2" Margin="12,0,0,0"
                                BorderThickness="0" Background="Transparent"
                                Click="DismissBanner_Click"/>
                    </Grid>
                </Border>

                <!-- ── Main content ─────────────────────────────────────────── -->
                <Grid Grid.Row="4" Margin="14,12,14,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- LEFT: Tunnels only -->
                    <Grid Grid.Column="0" x:Name="LeftTunnelGrid">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*" MinHeight="80"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Tunnels header + count badge -->
                        <Grid Grid.Row="0" Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="{Binding [SectionTunnels], Source={x:Static local:Lang.Instance}}"
                                       Style="{StaticResource SectionLabel}" Margin="0"/>
                            <Border Grid.Column="1" x:Name="TunnelCountBadge"
                                    Background="{DynamicResource BorderColor}"
                                    CornerRadius="8" Padding="6,1" Margin="6,0,0,0"
                                    VerticalAlignment="Center">
                                <TextBlock x:Name="TunnelCountLabel"
                                           FontSize="9"
                                           Foreground="{DynamicResource TextMuted}" Text="0"/>
                            </Border>
                        </Grid>

                        <!-- Group tab strip — rebuilt by RebuildTunnelGroups() -->
                        <Border Grid.Row="1"
                                Background="{DynamicResource Surface}"
                                BorderBrush="{DynamicResource BorderColor}" BorderThickness="0,0,0,1"
                                Margin="0,0,0,0">
                            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                          VerticalScrollBarVisibility="Disabled"
                                          Background="Transparent">
                                <StackPanel x:Name="TunnelTabButtons"
                                            Orientation="Horizontal"
                                            Background="Transparent"/>
                            </ScrollViewer>
                        </Border>

                        <!-- The active-tab ListView — ItemsSource swapped by RebuildTunnelGroups -->
                        <ListView Grid.Row="2" x:Name="TunnelsListView"
                                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                                  SelectionChanged="TunnelsListView_SelectionChanged">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="{Binding [TunnelColName], Source={x:Static local:Lang.Instance}}" Width="150">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Name}"
                                                           Foreground="{Binding NameColor}"
                                                           TextDecorations="{Binding NameDecoration}"
                                                           FontSize="11"
                                                           ToolTip="{Binding Notes}"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Header="{Binding [TunnelColType], Source={x:Static local:Lang.Instance}}" Width="65">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding TypeLabel}"
                                                           Foreground="{Binding TypeColor}"
                                                           FontSize="10"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Header="{Binding [TunnelColStatus], Source={x:Static local:Lang.Instance}}" Width="90">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding StatusText}"
                                                           Foreground="{Binding StatusColor}" FontSize="11"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Header="{Binding [TunnelColAction], Source={x:Static local:Lang.Instance}}" Width="90">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <Button Content="{Binding ButtonLabel}"
                                                        IsEnabled="{Binding ButtonEnabled}"
                                                        ToolTip="{Binding ButtonTooltip}"
                                                        Click="TunnelToggle_Click"
                                                        Padding="8,2" FontSize="10"
                                                        Style="{StaticResource FlatBtn}"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                </GridView>
                            </ListView.View>
                        </ListView>

                        <!-- Tunnel management buttons -->
                        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,6,0,0">
                            <Button Content="{Binding [BtnAddTunnel], Source={x:Static local:Lang.Instance}}"
                                    x:Name="AddTunnelBtn"
                                    Style="{StaticResource SuccessBtn}" FontSize="10" Padding="10,3"
                                    Click="AddTunnel_Click"/>
                            <Button Content="{Binding [BtnEditTunnel], Source={x:Static local:Lang.Instance}}"
                                    Style="{StaticResource FlatBtn}" FontSize="10" Padding="10,3"
                                    Margin="6,0,0,0" x:Name="EditTunnelBtn" IsEnabled="False"
                                    Click="EditTunnel_Click"/>
                            <Button Content="{Binding [BtnImportTunnel], Source={x:Static local:Lang.Instance}}"
                                    Style="{StaticResource FlatBtn}" FontSize="10" Padding="10,3"
                                    Margin="6,0,0,0"
                                    Click="ImportTunnel_Click"/>
                            <Button x:Name="DeleteTunnelBtn"
                                    Style="{StaticResource DangerBtn}" FontSize="10" Padding="10,3"
                                    Margin="6,0,0,0" IsEnabled="False" Visibility="Collapsed"
                                    Click="DeleteTunnel_Click"/>
                        </StackPanel>

                    </Grid>

                    <!-- RIGHT: Activity Log -->
                    <Grid Grid.Column="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- ACTIVITY LOG header -->
                        <Grid Grid.Row="0" Margin="0,0,0,4">
                            <TextBlock Text="{Binding [RTabLog], Source={x:Static local:Lang.Instance}}"
                                       Style="{StaticResource SectionLabel}" Margin="0"/>
                        </Grid>

                        <!-- Log content -->
                        <Border Grid.Row="1"
                                Background="{DynamicResource CardBg}"
                                BorderBrush="{DynamicResource BorderColor}" BorderThickness="1"
                                CornerRadius="{DynamicResource Theme.CornerRadius}">
                            <RichTextBox x:Name="LogBox"
                                         Background="Transparent"
                                         Foreground="{DynamicResource TextMuted}"
                                         FontSize="10"
                                         BorderThickness="0" IsReadOnly="True"
                                         Padding="8"
                                         VerticalScrollBarVisibility="Auto"
                                         HorizontalScrollBarVisibility="Disabled">
                                <FlowDocument x:Name="LogDocument"/>
                            </RichTextBox>
                        </Border>

                        <!-- Export button -->
                        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,6,0,0">
                            <Button Content="{Binding [BtnExportLog], Source={x:Static local:Lang.Instance}}"
                                    Style="{StaticResource FlatBtn}" FontSize="10" Padding="10,3"
                                    Click="ExportLog_Click"/>
                        </StackPanel>

                    </Grid>
                </Grid>

                <!-- ── Footer ─────────────────────────────────────────────── -->
                <Border Grid.Row="5" Background="{DynamicResource Surface}"
                        CornerRadius="{DynamicResource Theme.CornerRadiusBottom}">
                    <Grid Margin="14,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="FooterLabel" Grid.Column="0"
                                   Foreground="{DynamicResource TextMuted}" FontSize="10"
                                   VerticalAlignment="Center"/>
                        <TextBlock x:Name="AdminLabel" Grid.Column="1"
                                   HorizontalAlignment="Right" FontSize="10"
                                   VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <ResizeGrip Grid.Row="5" HorizontalAlignment="Right"
                            VerticalAlignment="Bottom" Margin="0,0,2,2" Opacity="0.4"
                            Visibility="{DynamicResource Theme.ShowResizeGrip}"/>
            </Grid>
        </Grid>
    </Border>
</Window>
