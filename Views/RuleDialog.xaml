<Window x:Class="WGWifiSwitcher.Views.RuleDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add Rule"
        Height="240" Width="420"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterOwner">

    <Border Background="{StaticResource Panel}"
            BorderBrush="{StaticResource Accent}"
            BorderThickness="1" CornerRadius="6">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="52"/>
            </Grid.RowDefinitions>

            <!-- Title -->
            <Border Grid.Row="0" Background="{StaticResource Bg}"
                    CornerRadius="6,6,0,0"
                    MouseLeftButtonDown="Title_MouseDown">
                <TextBlock x:Name="DialogTitle" Text="Add Rule"
                           FontFamily="Consolas" FontSize="12" FontWeight="Bold"
                           Foreground="{StaticResource Accent}"
                           Margin="16,0" VerticalAlignment="Center"/>
            </Border>

            <!-- Fields -->
            <Grid Grid.Row="1" Margin="20,14,20,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="14"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- SSID -->
                <TextBlock Grid.Row="0" Grid.ColumnSpan="2"
                           Text="WiFi Network (SSID)"
                           FontSize="10" Foreground="{StaticResource Sub}" Margin="0,0,0,4"/>
                <TextBox Grid.Row="1" Grid.Column="0" x:Name="SsidBox" Margin="0,0,8,0"/>
                <Button  Grid.Row="1" Grid.Column="1"
                         Content="Use Current" Style="{StaticResource FlatBtn}"
                         FontSize="10" Padding="10,6" Click="UseCurrent_Click"/>

                <!-- Tunnel name -->
                <TextBlock Grid.Row="3" Grid.ColumnSpan="2"
                           Text="WireGuard Tunnel Name  (leave blank to disconnect)"
                           FontSize="10" Foreground="{StaticResource Sub}" Margin="0,0,0,4"/>
                <TextBox Grid.Row="4" Grid.ColumnSpan="2" x:Name="TunnelBox"/>

                <TextBlock Grid.Row="5" Grid.ColumnSpan="2"
                           Text="Tip: name must match exactly as shown in the WireGuard app"
                           FontSize="9" Foreground="{StaticResource Sub}" Margin="0,5,0,0"
                           TextWrapping="Wrap"/>
            </Grid>

            <!-- Buttons -->
            <Border Grid.Row="2" Background="{StaticResource Bg}" CornerRadius="0,0,6,6">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                            Margin="0,0,16,0" VerticalAlignment="Center">
                    <Button Content="Cancel" Style="{StaticResource FlatBtn}"
                            Margin="0,0,8,0" Click="Cancel_Click"/>
                    <Button Content="Save Rule" Style="{StaticResource PrimaryBtn}"
                            Click="Save_Click"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
