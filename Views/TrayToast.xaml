<Window x:Class="MasselGUARD.Views.TrayToast"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="320" SizeToContent="Height"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent" ResizeMode="NoResize"
        ShowInTaskbar="False" Topmost="True"
        WindowStartupLocation="Manual">

    <Border Background="{DynamicResource Surface}"
            BorderBrush="{DynamicResource Accent}"
            BorderThickness="1" CornerRadius="{DynamicResource Theme.CornerRadius}">
        <StackPanel>

            <!-- Header: app icon + name -->
            <Border Background="{DynamicResource WindowBg}"
                    CornerRadius="{DynamicResource Theme.CornerRadiusTop}"
                    Padding="12,9">
                <StackPanel Orientation="Horizontal">
                    <!-- Custom logo -->
                    <Image Source="{DynamicResource Theme.Logo}"
                           Width="16" Height="16"
                           Visibility="{DynamicResource Theme.HasLogo}"
                           VerticalAlignment="Center" Margin="0,0,8,0"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                    <!-- Built-in icon -->
                    <Image x:Name="AppIcon" Width="16" Height="16"
                           Visibility="{DynamicResource Theme.HasBuiltinIcon}"
                           VerticalAlignment="Center" Margin="0,0,8,0"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                    <TextBlock Text="{DynamicResource Theme.AppName}"
                               FontFamily="{DynamicResource Theme.FontFamily}" FontSize="12" FontWeight="Bold"
                               Foreground="{DynamicResource Accent}"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Divider -->
            <Rectangle Height="1" Fill="{DynamicResource BorderColor}"/>

            <!-- Message body -->
            <Border Background="{DynamicResource Surface}" Padding="14,13">
                <TextBlock x:Name="MessageLabel"
                           FontFamily="{DynamicResource Theme.FontFamily}" FontSize="15"
                           Foreground="{DynamicResource TextPrimary}"
                           TextWrapping="Wrap" LineHeight="22"
                           MaxWidth="270"/>
            </Border>

        </StackPanel>
    </Border>
</Window>
