<Window x:Class="MasselGUARD.Views.TrayToast"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="320" SizeToContent="Height"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent" ResizeMode="NoResize"
        ShowInTaskbar="False" Topmost="True"
        WindowStartupLocation="Manual">

    <Border Background="{StaticResource Panel}"
            BorderBrush="{StaticResource Accent}"
            BorderThickness="1" CornerRadius="6">
        <StackPanel>

            <!-- Header: app icon + name -->
            <Border Background="{StaticResource Bg}"
                    CornerRadius="6,6,0,0"
                    Padding="12,9">
                <StackPanel Orientation="Horizontal">
                    <Image x:Name="AppIcon" Width="16" Height="16"
                           VerticalAlignment="Center" Margin="0,0,8,0"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                    <TextBlock Text="MasselGUARD"
                               FontFamily="Consolas" FontSize="12" FontWeight="Bold"
                               Foreground="{StaticResource Accent}"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Divider -->
            <Rectangle Height="1" Fill="{StaticResource Border}"/>

            <!-- Message body -->
            <Border Padding="14,13">
                <TextBlock x:Name="MessageLabel"
                           FontFamily="Consolas" FontSize="15"
                           Foreground="{StaticResource Text}"
                           TextWrapping="Wrap" LineHeight="22"
                           MaxWidth="270"/>
            </Border>

        </StackPanel>
    </Border>
</Window>
