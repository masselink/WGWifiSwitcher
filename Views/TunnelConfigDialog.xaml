<Window x:Class="MasselGUARD.Views.TunnelConfigDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:MasselGUARD"
        Title="{Binding [TunnelDialogAddTitle], Source={x:Static local:Lang.Instance}}"
        Width="560" Height="640"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent" ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterOwner">

    <Border Background="{DynamicResource WindowBg}"
            BorderBrush="{DynamicResource Accent}"
            BorderThickness="1" CornerRadius="{DynamicResource Theme.CornerRadius}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="44"/>   <!-- Title bar -->
                <RowDefinition Height="Auto"/> <!-- Tunnel name -->
                <RowDefinition Height="*"/>    <!-- Tabs -->
                <RowDefinition Height="52"/>   <!-- Button bar -->
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Border Grid.Row="0" Background="{DynamicResource Surface}"
                    CornerRadius="{DynamicResource Theme.CornerRadiusTop}"
                    MouseLeftButtonDown="TitleBar_MouseDown">
                <Grid>
                    <TextBlock x:Name="DialogTitle"
                               FontFamily="{DynamicResource Theme.FontFamily}" FontSize="13" FontWeight="Bold"
                               Foreground="{DynamicResource Accent}"
                               VerticalAlignment="Center" Margin="16,0"/>
                    <Button Content="✕" Style="{StaticResource DangerBtn}"
                            HorizontalAlignment="Right" Padding="10,4" Margin="0,0,8,0"
                            BorderThickness="0" Background="Transparent"
                            Click="CancelBtn_Click"/>
                </Grid>
            </Border>

            <!-- Tunnel name — above tabs, always visible -->
            <Border Grid.Row="1"
                    Background="{DynamicResource WindowBg}"
                    BorderBrush="{DynamicResource BorderColor}" BorderThickness="0,0,0,1"
                    Padding="16,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="160"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="{Binding [TunnelDialogName], Source={x:Static local:Lang.Instance}}"
                               Style="{StaticResource FormLabel}"
                               VerticalAlignment="Center"
                               Margin="0,0,12,0"/>
                    <TextBox Grid.Column="1" x:Name="NameBox"
                             FontFamily="{DynamicResource Theme.FontFamily}" FontSize="12"/>
                    <TextBlock Grid.Column="2"
                               Text="{Binding [TunnelDialogGroup], Source={x:Static local:Lang.Instance}}"
                               Style="{StaticResource FormLabel}"
                               VerticalAlignment="Center"
                               Margin="12,0,8,0"/>
                    <ComboBox Grid.Column="3" x:Name="GroupPicker"
                              FontFamily="{DynamicResource Theme.FontFamily}" FontSize="11"/>
                </Grid>
            </Border>

            <!-- Tab control: Fields / Raw -->
            <TabControl Grid.Row="2" x:Name="Tabs"
                        Background="{DynamicResource WindowBg}"
                        BorderBrush="{DynamicResource BorderColor}"
                        BorderThickness="0"
                        Margin="0">
                <TabControl.Resources>
                    <Style TargetType="TabItem">
                        <Setter Property="FontFamily" Value="Consolas"/>
                        <Setter Property="FontSize"   Value="11"/>
                        <Setter Property="Padding"    Value="14,7"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="TabItem">
                                    <Border x:Name="TabBorder"
                                            Background="{DynamicResource Surface}"
                                            BorderBrush="{DynamicResource BorderColor}"
                                            BorderThickness="1,1,1,0"
                                            CornerRadius="4,4,0,0"
                                            Margin="0,0,2,0"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter x:Name="TabLabel"
                                                          ContentSource="Header"
                                                          TextBlock.Foreground="{DynamicResource TextMuted}"
                                                          TextBlock.FontFamily="{DynamicResource Theme.FontFamily}"
                                                          TextBlock.FontSize="11"
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="TabBorder" Property="Background"
                                                    Value="{DynamicResource WindowBg}"/>
                                            <Setter TargetName="TabBorder" Property="BorderBrush"
                                                    Value="{DynamicResource Accent}"/>
                                            <Setter TargetName="TabLabel"
                                                    Property="TextBlock.Foreground"
                                                    Value="{DynamicResource Accent}"/>
                                            <Setter TargetName="TabLabel"
                                                    Property="TextBlock.FontWeight"
                                                    Value="Bold"/>
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="TabBorder" Property="Background"
                                                    Value="{DynamicResource CardBg}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </TabControl.Resources>

                <!-- Fields tab -->
                <TabItem x:Name="TabFields"
                         Header="{Binding [TunnelDialogTabForm], Source={x:Static local:Lang.Instance}}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20,16">
                        <StackPanel>

                            <!-- INTERFACE -->
                            <TextBlock Text="{Binding [TunnelDialogInterface], Source={x:Static local:Lang.Instance}}"
                                       Style="{StaticResource SectionLabel}" Margin="0,0,0,8"/>

                            <TextBlock Text="{Binding [TunnelDialogPrivateKey], Source={x:Static local:Lang.Instance}}"
                                       Style="{StaticResource FormLabel}"/>
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="PrivateKeyBox" Grid.Column="0" Margin="0,0,6,0"
                                         FontFamily="{DynamicResource Theme.FontFamily}" FontSize="10"/>
                                <Button Grid.Column="1"
                                        Content="{Binding [BtnGenerateKey], Source={x:Static local:Lang.Instance}}"
                                        Style="{StaticResource FlatBtn}" FontSize="10" Padding="10,6"
                                        Click="GenerateKey_Click"/>
                            </Grid>

                            <TextBlock Text="{Binding [TunnelDialogAddress], Source={x:Static local:Lang.Instance}}"
                                       Style="{StaticResource FormLabel}"/>
                            <TextBox x:Name="AddressBox" Margin="0,0,0,10" FontFamily="{DynamicResource Theme.FontFamily}" FontSize="11"/>

                            <TextBlock Text="{Binding [TunnelDialogDns], Source={x:Static local:Lang.Instance}}"
                                       Style="{StaticResource FormLabel}"/>
                            <TextBox x:Name="DnsBox" Margin="0,0,0,10" FontFamily="{DynamicResource Theme.FontFamily}" FontSize="11"/>

                            <TextBlock Text="{Binding [TunnelDialogListenPort], Source={x:Static local:Lang.Instance}}"
                                       Style="{StaticResource FormLabel}"/>
                            <TextBox x:Name="ListenPortBox" Margin="0,0,0,10" FontFamily="{DynamicResource Theme.FontFamily}" FontSize="11"/>

                            <TextBlock Text="{Binding [TunnelDialogMtu], Source={x:Static local:Lang.Instance}}"
                                       Style="{StaticResource FormLabel}"/>
                            <TextBox x:Name="MtuBox" Margin="0,0,0,14" FontFamily="{DynamicResource Theme.FontFamily}" FontSize="11"/>

                            <!-- PEER -->
                            <TextBlock Text="{Binding [TunnelDialogPeer], Source={x:Static local:Lang.Instance}}"
                                       Style="{StaticResource SectionLabel}" Margin="0,4,0,8"/>

                            <TextBlock Text="{Binding [TunnelDialogPublicKey], Source={x:Static local:Lang.Instance}}"
                                       Style="{StaticResource FormLabel}"/>
                            <TextBox x:Name="PublicKeyBox" Margin="0,0,0,10" FontFamily="{DynamicResource Theme.FontFamily}" FontSize="10"/>

                            <TextBlock Text="{Binding [TunnelDialogPresharedKey], Source={x:Static local:Lang.Instance}}"
                                       Style="{StaticResource FormLabel}"/>
                            <TextBox x:Name="PresharedKeyBox" Margin="0,0,0,10" FontFamily="{DynamicResource Theme.FontFamily}" FontSize="10"/>

                            <TextBlock Text="{Binding [TunnelDialogEndpoint], Source={x:Static local:Lang.Instance}}"
                                       Style="{StaticResource FormLabel}"/>
                            <TextBox x:Name="EndpointBox" Margin="0,0,0,10" FontFamily="{DynamicResource Theme.FontFamily}" FontSize="11"/>

                            <TextBlock Text="{Binding [TunnelDialogAllowedIPs], Source={x:Static local:Lang.Instance}}"
                                       Style="{StaticResource FormLabel}"/>
                            <TextBox x:Name="AllowedIPsBox" Margin="0,0,0,10" FontFamily="{DynamicResource Theme.FontFamily}" FontSize="11"/>

                            <TextBlock Text="{Binding [TunnelDialogKeepalive], Source={x:Static local:Lang.Instance}}"
                                       Style="{StaticResource FormLabel}"/>
                            <TextBox x:Name="KeepaliveBox" Margin="0,0,0,10" FontFamily="{DynamicResource Theme.FontFamily}" FontSize="11"/>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- Raw config tab -->
                <TabItem x:Name="TabRaw"
                         Header="{Binding [TunnelDialogTabRaw], Source={x:Static local:Lang.Instance}}"
                         GotFocus="TabRaw_GotFocus">
                    <Grid Margin="12">
                        <TextBox x:Name="RawBox"
                                 AcceptsReturn="True" AcceptsTab="True"
                                 FontFamily="{DynamicResource Theme.FontFamily}" FontSize="11"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Auto"
                                 TextWrapping="NoWrap"
                                 VerticalAlignment="Stretch"/>
                    </Grid>
                </TabItem>
            </TabControl>

            <!-- Button bar -->
            <Border Grid.Row="3" Background="{DynamicResource Surface}" CornerRadius="{DynamicResource Theme.CornerRadiusBottom}">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                            VerticalAlignment="Center" Margin="0,0,16,0">
                    <Button Content="{Binding [BtnCancel], Source={x:Static local:Lang.Instance}}"
                            Style="{StaticResource FlatBtn}" Padding="20,6" Margin="0,0,8,0"
                            Click="CancelBtn_Click"/>
                    <Button Content="{Binding [BtnSaveTunnel], Source={x:Static local:Lang.Instance}}"
                            Style="{StaticResource PrimaryBtn}" Padding="20,6"
                            Click="SaveBtn_Click"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
